<% layout('layouts/boilerplate') %>
<body>
    <div class="row mt-3">
        <h1 class="offset-2">Create New Listings</h1>
        <div class="col-8 offset-2" >
            <form action="/listings" method="post" novalidate class="needs-validation">

                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" placeholder="Add a title" required class="form-control">
                    <div class="invalid-feedback">
                        Please provide a title.
                    </div>
                    <div class="valid-feedback">
                        Title looks good.
                    </div>
                </div>

               
                
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" required class="form-control"></textarea>
                    <div class="invalid-feedback">
                        Please provide a description.
                    </div>
                
                <br>

                <div class="mb-3">
                    <label for="image" class="form-label">Image URL</label>
                    <input type="text" name="listing[image][url]" placeholder="Image URL"  class="form-control">
                
                </div>

                <br>

                <div class="row">
                    <div class="mb-3 col-md-4" >
                        <label for="price" class="form-label">Price</label>
                        <input type="number" name="listing[price]" placeholder="Price" required class="form-control">
                    <div class="invalid-feedback">
                        Please provide a price.
                    </div>
                    <div class="valid-feedback">
                        Price looks good.
                    </div>
                    </div>
                
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" placeholder="Country" required class="form-control">
                    <div class="invalid-feedback">
                        Please provide a country.   
                    </div>
                    <div class="valid-feedback">
                        Country looks good. 
                    </div>

                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" placeholder="Location" required class="form-control">
                    <div class="invalid-feedback">
                        Please provide a location.
                    </div>
                    <div class="valid-feedback">
                        Location looks good.
                    </div>
                </div>
            
                <button class="btn btn-dark add-btn mt-3">Create Listing</button>
                <br>
            </form>
            <br>
        </div>
    </div>
    
