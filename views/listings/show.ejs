<% layout('layouts/boilerplate') %>
    <div class="row">
        <div class="col-8 offset-3 mt-3">
            <h3><%= listing.title %></h3> <br>
        </div>
            <div class="card col-6 offset-3 show-card listing-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="Listing_image">
                <div class="card-body">
                    
                        <!-- <b><%= listing.title %></b><br><br> -->
                        <p class="card-text"><i>owned by <%= listing.owner.username %></i></p>
                        <p class="card-text"><%= listing.description %></p>
                        
                        <p class="card-text"></p>&#8377;<%= listing.price.toLocaleString("en-IN") %> per night<br></p>
                        <p class="card-text"></p>Location: <%= listing.location %>, <%= listing.country %></p>

                    
                </div>
            </div>
            <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
             <div class="btns">
                <a href="/listings/<%= listing.id %>/edit" class="btn btn-dark col-1 offset-3">Edit</a>
             
                <form action="/listings/<%= listing.id %>?_method=DELETE"  method="POST"><button class="btn btn-dark   offset-4">Delete</button></form>
            </div>
            <% } %>
            <div class="col-8 offset-3 mt-5 mb-3">
                <hr>
                <% if(currUser){ %>
                <h4>Leave a review</h4>
                <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
                    <div class="mb-3 mt-3" >
                        <label for="rating" class="form-label">Rating</label>
                        <input type="range" id="rating" name="review[rating]" min="1" max="5" >
                        
                    </div>
                    <div class="mb-3 mt-3">
                        <label for="comment" class="form-label">Comment:</label><br>
                        <textarea id="comment" name="review[comment]" rows="4" cols="50" class="form-control" required></textarea>
                    
                        <div class="invalid-feedback">
                                Please enter a comment. </div>
                    </div>
                    <button class="btn btn-outline-dark">Submit</button>
                </form>
                <% } %>
                <hr/>

                <h4>All Reviews</h4>
                <!-- <p> <%= listing.reviews %> </p> -->
                <!-- <ul>
                <% for(review of listing.reviews){ %>
                    <li><%= review.comment %> , <%= review.rating %> </li>

                <% } %>
                </ul> -->

                <div class="row">
                <% for(review of listing.reviews){ %>
                    <div class="card col-5 ms-3 mb-3">
                        <div class="card-body">
                            <h5 class="card-title"><%= review.author.username %></h5>
                            <p class="card-text"><%= review.comment %></p>
                            <p class="card-text">Rating: <%= review.rating %> </p>
                        </div>
                        <form class="mb-3" method="post" action="/listings/<%= listing.id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-danger">Delete</button>
                        </form>
                        
                    </div>

                <% } %>
                </div>
            </div>
            

        
    </div>
